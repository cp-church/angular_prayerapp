{
  "name": "prayerapp",
  "private": true,
  "version": "0.0.0",
  "engines": {
    "node": ">=22.22.3"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:dev": "ng build --configuration development",
    "build:prod": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --run --coverage && node scripts/coverage-report.js",
    "lint": "eslint --quiet \"src/app/**/*.ts\" \"src/lib/**/*.ts\"",
    "typecheck": "ng build --configuration development",
    "verify": "npm run typecheck && npm test -- --run",
    "pre-handoff": "node scripts/pre-handoff.js",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:debug": "playwright test --debug",
    "e2e:report": "playwright show-report",
    "cap:icons": "cp public/apple-touch-icon.png resources/logo.png && npx @capacitor/assets generate --iconBackgroundColor '#1a365d' --iconBackgroundColorDark '#1a365d' --splashBackgroundColor '#1a365d' --splashBackgroundColorDark '#1a365d'",
    "cap:icons:generate": "npx @capacitor/assets generate --iconBackgroundColor '#1a365d' --iconBackgroundColorDark '#1a365d' --splashBackgroundColor '#1a365d' --splashBackgroundColorDark '#1a365d'",
    "cap:sync": "npx cap sync",
    "cap:open": "npx cap open ios",
    "cap:dev": "ng build --configuration development && npx cap sync",
    "cap:prod": "ng build --configuration production && npx cap sync",
    "resize-app-store-screenshots": "node scripts/resize-app-store-screenshots.js",
    "postinstall": "node scripts/patch-printer-printHtml.js"
  },
  "dependencies": {
    "@angular/animations": "^22.0.4",
    "@angular/cdk": "^22.0.2",
    "@angular/common": "^22.0.4",
    "@angular/compiler": "^22.0.4",
    "@angular/core": "^22.0.4",
    "@angular/forms": "^22.0.4",
    "@angular/platform-browser": "^22.0.4",
    "@angular/platform-browser-dynamic": "^22.0.4",
    "@angular/router": "^22.0.4",
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/push-notifications": "^8.1.1",
    "@capgo/capacitor-printer": "^8.1.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@planningcenter/api-client": "^3.1.0",
    "@supabase/supabase-js": "^2.110.0",
    "@tiptap/core": "^3.27.1",
    "@tiptap/extension-underline": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "chart.js": "^4.5.1",
    "dompurify": "^3.4.11",
    "driver.js": "^1.6.0",
    "lucide-angular": "^0.563.0",
    "marked": "^18.0.5",
    "posthog-js": "^1.396.3",
    "rxjs": "^7.8.2",
    "tiptap-markdown": "^0.9.0",
    "tslib": "^2.8.1",
    "zone.js": "^0.16.2"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^22.0.4",
    "@angular/cli": "^22.0.4",
    "@angular/compiler-cli": "^22.0.4",
    "@capacitor/assets": "^3.0.5",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/angular": "^19.4.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^25.2.3",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "angular-eslint": "^22.0.0",
    "autoprefixer": "^10.5.2",
    "eslint": "^9.39.4",
    "happy-dom": "^20.10.6",
    "jsdom": "^28.0.0",
    "patch-package": "^8.0.1",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  }
}
